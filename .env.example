# ═══ KAPTURISE AI AGENTS ═══
# Copy to .env.local and fill in your values

# Supabase (Required for database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# AI (Required — powers all agents)
NEXT_PUBLIC_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Image Generation (Optional)
NEXT_PUBLIC_GEMINI_API_KEY=your-google-ai-key

# Phone Calls (Optional)
NEXT_PUBLIC_BLAND_API_KEY=your-bland-key
NEXT_PUBLIC_BLAND_PHONE=+971XXXXXXXXX
